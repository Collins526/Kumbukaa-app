{
  "info": {
    "name": "Kumbukaa Lending App API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the Kumbukaa backend API. Set {{baseUrl}} to http://localhost:8080/kumbukaa for local testing. Users can borrow from and lend to other users without needing to select a role."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/kumbukaa"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "authId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "borrowerId",
      "value": ""
    },
    {
      "key": "lenderId",
      "value": ""
    },
    {
      "key": "loanId",
      "value": ""
    },
    {
      "key": "transactionId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phoneNumber\": \"0712345678\",\n  \"password\": \"Password123!\",\n  \"confirmPassword\": \"Password123!\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) pm.environment.set('token', jsonData.token);",
                  "if (jsonData.refreshToken) pm.environment.set('refreshToken', jsonData.refreshToken);",
                  "if (jsonData.id) pm.environment.set('authId', jsonData.id);",
                  "if (jsonData.userId) pm.environment.set('userId', jsonData.userId);",
                  "pm.test('Login returned token', function () { pm.expect(jsonData.token).to.be.a('string'); });"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/request-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","request-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
