{
  "info": {
    "name": "Kumbukaa Lending App API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the Kumbukaa backend API. Set {{baseUrl}} to http://localhost:8080/kumbukaa for local testing. Users can borrow from and lend to other users without needing to select a role."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/kumbukaa"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "authId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "lenderUserId",
      "value": ""
    },
    {
      "key": "borrowerUserId",
      "value": ""
    },
    {
      "key": "loanId",
      "value": ""
    },
    {
      "key": "transactionId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phoneNumber\": \"0712345678\",\n  \"password\": \"Password123!\",\n  \"confirmPassword\": \"Password123!\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) pm.environment.set('token', jsonData.token);",
                  "if (jsonData.refreshToken) pm.environment.set('refreshToken', jsonData.refreshToken);",
                  "if (jsonData.id) pm.environment.set('authId', jsonData.id);",
                  "if (jsonData.userId) pm.environment.set('userId', jsonData.userId);",
                  "pm.test('Login returned token', function () { pm.expect(jsonData.token).to.be.a('string'); });"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/request-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","request-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","refresh-token"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout/{{authId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","logout","{{authId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/validate-token",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","validate-token"]
            }
          },
          "response": []
        },
        {
          "name": "Get Auth by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/{{authId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","{{authId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Get Auth by User ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/user/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","user","{{userId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Auth",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/all",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","all"]
            }
          },
          "response": []
        },
        {
          "name": "Update Auth",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/{{authId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","{{authId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": {{authId}},\n  \"email\": \"john@example.com\",\n  \"username\": \"john@example.com\",\n  \"isVerified\": true,\n  \"isActive\": true\n}"
            }
          },
          "response": []
        },
        {
          "name": "Verify Auth",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/{{authId}}/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","{{authId}}","verify"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Auth",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/{{authId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","{{authId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Loans",
      "item": [

        {
          "name": "Accept Loan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/loans/{{loanId}}/accept",
              "host": ["{{baseUrl}}"],
              "path": ["api","loans","{{loanId}}","accept"]
            }
          },
          "response": []
        },
        {
          "name": "Get Loan by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/loans/{{loanId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","loans","{{loanId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Create Loan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/loans?lenderId={{lenderUserId}}&borrowerId={{borrowerUserId}}&amount=5000",
              "host": ["{{baseUrl}}"],
              "path": ["api","loans"],
              "query": [
                { "key": "lenderId", "value": "{{lenderUserId}}" },
                { "key": "borrowerId", "value": "{{borrowerUserId}}" },
                { "key": "amount", "value": "5000" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get All Loans",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/loans/all",
              "host": ["{{baseUrl}}"],
              "path": ["api","loans","all"]
            }
          },
          "response": []
        },



        {
          "name": "Delete Loan",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/loans/{{loanId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","loans","{{loanId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Log Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transactions?loanId={{loanId}}&amount=1500&mpesaCode=MPESA123",
              "host": ["{{baseUrl}}"],
              "path": ["api","transactions"],
              "query": [
                { "key": "loanId", "value": "{{loanId}}" },
                { "key": "amount", "value": "1500" },
                { "key": "mpesaCode", "value": "MPESA123" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Approve Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["api","transactions","{{transactionId}}","approve"]
            }
          },
          "response": []
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","transactions","{{transactionId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transactions/all",
              "host": ["{{baseUrl}}"],
              "path": ["api","transactions","all"]
            }
          },
          "response": []
        },
        {
          "name": "Get Transactions by Loan",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transactions/loan/{{loanId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","transactions","loan","{{loanId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Get by MPESA Code",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transactions/mpesa/MPESA123",
              "host": ["{{baseUrl}}"],
              "path": ["api","transactions","mpesa","MPESA123"]
            }
          },
          "response": []
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","transactions","{{transactionId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": {{transactionId}},\n  \"loan\": { \"id\": {{loanId}} },\n  \"amount\": 1500.0,\n  \"mpesaTransactionId\": \"MPESA123\",\n  \"status\": \"PENDING\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","transactions","{{transactionId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Debug",
      "item": [
        {
          "name": "Dump All Tables",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/debug/dump",
              "host": ["{{baseUrl}}"],
              "path": ["api","debug","dump"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
