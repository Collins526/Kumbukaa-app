        {
          "name": "Delete Auth",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/{{authId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","auth","{{authId}}"]
            }
          },
          "response": []
