            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData && jsonData.id) {",
                  "    pm.environment.set('lenderId', jsonData.id);",
                  "    pm.test('Lender ID captured', function () { pm.expect(jsonData.id).to.be.a('number'); });",
                  "  } else {",
                  "    pm.test('Create Lender returned no id', function () { pm.expect(typeof jsonData).to.not.equal('undefined'); });",
                  "  }",
                  "} catch (e) {",
                  "  pm.test('Response is not JSON', function () { pm.expect(pm.response.text()).to.be.a('string'); });",
                  "}"
                ]
              }
            }
          ],
