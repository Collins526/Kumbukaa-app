# Copy this file to .env and fill in your real secrets.

SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_DB_HOST:5432/YOUR_DB_NAME
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=your_db_password

APP_JWT_SECRET=your_jwt_secret_key

SPRING_MAIL_USERNAME=your_email@example.com
SPRING_MAIL_PASSWORD=your_email_password

APP_RESEND_API_KEY=your_resend_api_key
APP_RESEND_FROM_EMAIL=onboarding@resend.dev
